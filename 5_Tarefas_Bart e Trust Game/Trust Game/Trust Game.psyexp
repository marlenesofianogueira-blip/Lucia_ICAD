    <Routine name="trial"/>
    <Routine name="Decision1"/>
    <Routine name="WaitForResponse"/>
    <Routine name="response"/>
    <Routine name="Feedback"/>
    <LoopTerminator name="trials1"/>
    <Routine name="EndScreen"/>
  </Flow>
</PsychoPy2experiment>
