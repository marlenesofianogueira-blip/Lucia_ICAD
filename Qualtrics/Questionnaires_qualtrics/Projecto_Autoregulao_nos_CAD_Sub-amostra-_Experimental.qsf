\u00e0 internet?","DefaultChoices":false,"DataExportTag":"Q175","QuestionType":"SBS","Selector":"SBSMatrix","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","ChoiceColumnWidthPixels":222,"RepeatHeaders":"all"},"QuestionDescription":"1. Por dia, quanto tempo est\u00e1 ligado \u00e0 internet?","Choices":{"1":{"Display":"a) Nas Redes Sociais"},"2":{"Display":"b) Em Jogos online"},"3":{"Display":"c)\tEm Jogos de apostas online","ExclusiveAnswer":true},"4":{"Display":"d) Visualiza\u00e7\u00e3o de Videos"},"5":{"Display":"e) Utiliza\u00e7\u00e3o de sites para encontros"},"6":{"Display":"f) Utiliza\u00e7\u00e3o de plataformas online e f\u00f3runs de discuss\u00e3o\/informa\u00e7\u00e3o"},"7":{"Display":"g) Realiza\u00e7\u00e3o de compras online"}},"DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID140\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">Se<\/span> <span class=\"QuestionDesc\">Idade de in\u00edcio de utiliza\u00e7\u00e3o da internet<\/span> <span class=\"LeftOpDesc\">Nunca usei<\/span> <span class=\"OpDesc\">N\u00e3o est\u00e1 selecionado<\/span> ","LeftOperand":"q:\/\/QID140\/SelectableChoice\/1","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID140","QuestionIDFromLocator":"QID140","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[1,2,3,"4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":3,"NumberOfQuestions":2,"AdditionalQuestions":{"1":{"Answers":{"1":{"Display":"Nunca"},"2":{"Display":"At\u00e9 1h"},"3":{"Display":"2h-3h"},"4":{"Display":"4h-5h"},"5":{"Display":"6h ou mais"}},"QuestionText":"De 2\u00aa a 6\u00aa (Escolhe uma op\u00e7\u00e3o por linha)","RecodeValues":[],"VariableNaming":[],"AnalyzeChoices":[],"QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","ChoiceColumn