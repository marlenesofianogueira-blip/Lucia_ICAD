tion value=\"sim\">Sim<\/option>\n  <\/select>\n<\/div>\n\n\n<div id=\"caixaTexto\" style=\"display: none;\" class=\"pergunta\">\n  Em que institui\u00e7\u00e3o?\n  <input type=\"text\" id=\"instituicao\" placeholder=\"Digite aqui\">\n<\/div>\n\n<script>\n  functio","DataExportTag":"Q172","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Q: J\u00e1 alguma vez teve acompanhamento pedopsiqui\u00e1trico, psicol\u00f3gico ou psiqui\u00e1trico? N\u00e3o Sim Em qu...","Choices":[],"ChoiceOrder":[],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID172"}},{"SurveyID":"SV_dbxOi9qlfeIGuRE","Element":"SQ","PrimaryAttribute":"QID173","SecondaryAttribute":"Em que Institui\u00e7\u00e3o?","TertiaryAttribute":null,"Payload":{"QuestionText":"Em que Institui\u00e7\u00e3o?","DefaultChoices":false,"DataExportTag":"Q173","QuestionID":"QID173","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Em que Institui\u00e7\u00e3o?","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidTextOnly","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"","Max":"","NumDecimals":""}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"DisplayLogic":{"0":{"0":{"LogicType":"Question","QuestionID":"QID39","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID39\/SelectableChoice\/1","Operator":"Selected","QuestionIDFromLocator":"QID39","LeftOperand":"q:\/\/QID39\/SelectableChoice\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">Se<\/span> <span class=\"QuestionDesc\">&amp;nbsp;J\u